{
  "name": "game1",
  "version": "0.1.0",
  "description": "A small cross-platform pixel roguelike built with Phaser and Electron.",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "package": "electron-builder",
    "package:mac": "electron-builder --mac",
    "package:win": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.codex.game1",
    "productName": "game1",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "index.html",
      "src/**/*",
      "public/**/*",
      "ATTRIBUTION.md",
      "package.json"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.games"
    },
    "win": {
      "target": "nsis"
    }
  }
}
